# ===========================================
# Nicki's Flavor House — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values.
# Never commit .env.local or any file containing secrets.

# --- Supabase ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-side only (Vercel API routes); do not expose to client
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
VITE_STRIPE_PUBLISHABLE_KEY=
# Server-side only
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Notifications ---
RESEND_API_KEY=
# Sender for order emails. Must be an address on a domain you verified in Resend (resend.dev can only send to the Resend account owner).
# Example: orders@nickisflavorhouse.com (after verifying nickisflavorhouse.com in Resend dashboard)
RESEND_FROM=
NTFY_TOPIC=
NICKI_EMAIL=

# --- Rate limiting (optional; create-checkout is rate limited when set) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- E2E (optional; for playwright order-flow.spec.js admin steps) ---
# PLAYWRIGHT_BASE_URL=http://localhost:5173
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=

# --- App / site copy (optional; defaults in siteConfig.js) ---
VITE_APP_URL=https://nickisflavorhouse.com
VITE_SITE_NAME=Nicki's Flavor House
VITE_SITE_TAGLINE=Homemade flavor, made with love. Order ahead for pickup.
VITE_PAYMENT_COPY=Pay deposit with Cash App or Zelle
VITE_INSTAGRAM_URL=https://instagram.com
VITE_PICKUP_ADDRESS=13505 Inwood Rd, Farmers Branch, TX 75244
VITE_LOCATION_CITY=Dallas, TX
