# ===========================================
# Nicki's Flavor House — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values.
# Never commit .env.local or any file containing secrets.

# --- Supabase ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-side only (Vercel API routes); do not expose to client
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
VITE_STRIPE_PUBLISHABLE_KEY=
# Server-side only
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Notifications ---
RESEND_API_KEY=
NTFY_TOPIC=
NICKI_EMAIL=

# --- App ---
VITE_APP_URL=https://nickisflavorhouse.com

# --- Instagram (Basic Display API) ---
INSTAGRAM_ACCESS_TOKEN=
