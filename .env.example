# ===========================================
# Nicki's Flavor House — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values.
# Never commit .env.local or any file containing secrets.

# --- Supabase ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-side only (Vercel API routes); do not expose to client
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
VITE_STRIPE_PUBLISHABLE_KEY=
# Server-side only
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Notifications ---
RESEND_API_KEY=
# Sender for order emails (e.g. onboarding@resend.dev or your verified domain)
RESEND_FROM=
NTFY_TOPIC=
NICKI_EMAIL=

# --- App / site copy (optional; defaults in siteConfig.js) ---
VITE_APP_URL=https://nickisflavorhouse.com
VITE_SITE_NAME=Nicki's Flavor House
VITE_SITE_TAGLINE=Homemade flavor, made with love. Order ahead for pickup.
VITE_PAYMENT_COPY=Pay deposit with Cash App or Zelle
VITE_INSTAGRAM_URL=https://instagram.com

# --- Instagram Graph API (business account) ---
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
# Full profile URL for "Follow on Instagram" link (e.g. https://instagram.com/username)
INSTAGRAM_PROFILE_URL=
